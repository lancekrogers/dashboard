# Dashboard configuration

# Daemon connection (for direct gRPC — dev only)
OBEY_DAEMON_SOCKET=${XDG_RUNTIME_DIR}/obey/daemon.sock

# Hub WebSocket (production: wss://api.obey.app/v1/events, local: ws://localhost:8080/ws)
NEXT_PUBLIC_HUB_WS_URL=wss://api.obey.app/v1/events

# gRPC/REST dev mode (set to true for direct daemon connection)
NEXT_PUBLIC_USE_GRPC=false
NEXT_PUBLIC_DAEMON_GRPC_URL=http://localhost:9090

# Hedera mirror node
NEXT_PUBLIC_HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
NEXT_PUBLIC_HEDERA_TOPIC_IDS=0.0.12345,0.0.12346
